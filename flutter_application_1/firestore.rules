rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check for rule evaluation.
    // Supports setups where admin documents are keyed by Firebase uid
    // or by admin email in the admins collection.
    function isAdmin() {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            request.auth.token.email != null
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
          )
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/favorites/{journeyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Transport data collections
    match /journeys/{journeyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /stations/{stationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /community_messages/{messageId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'avatarId',
          'text',
          'timestamp',
          'replyTo'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 64
        && request.resource.data.avatarId is string
        && request.resource.data.avatarId.size() > 0
        && request.resource.data.avatarId.size() <= 64
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.timestamp is timestamp
        && (
          !('replyTo' in request.resource.data)
          || (
            request.resource.data.replyTo is map
            && request.resource.data.replyTo.keys().hasOnly(['messageId', 'text', 'username'])
            && request.resource.data.replyTo.messageId is string
            && request.resource.data.replyTo.messageId.size() > 0
            && request.resource.data.replyTo.text is string
            && request.resource.data.replyTo.text.size() <= 120
            && request.resource.data.replyTo.username is string
            && request.resource.data.replyTo.username.size() > 0
            && request.resource.data.replyTo.username.size() <= 64
          )
        );

      allow update, delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Admin profiles are sensitive and must only be visible to admins.
    // Write access is permanently disabled to prevent unauthorized admin creation.
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

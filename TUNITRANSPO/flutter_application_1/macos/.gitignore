# Firebase credentials — regenerate locally with: flutterfire configure
# lib/firebase_options.dart is committed with placeholder values so the
# project compiles from a fresh clone.  Run `flutterfire configure` to
# overwrite it with real credentials.  Use `git update-index --skip-worktree
# lib/firebase_options.dart` to keep real credentials out of future commits.
android/app/google-services.json
android/app/src/google-services.json
ios/Runner/GoogleService-Info.plist

# Service account keys and local secret env files
scripts/firebase-key.json
scripts/firebase-*.json
.env
.env.*